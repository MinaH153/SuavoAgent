{
  "Agent": {
    "CloudUrl": "https://suavollc.com",
    "HeartbeatIntervalSeconds": 30,
    "HeartbeatJitterSeconds": 5,
    "Version": "3.13.9-dev",
    "LearningMode": false,
    "ReceiptOnlyMode": true,
    "TemplateLearning": {
      "Enabled": false,
      "Mode": "capture",
      "RuleGeneration": false,
      "AutoApproveOnFingerprintMatch": false,
      "MinRoutineConfidence": 0.6,
      "MinStepCount": 2,
      "MaxExpectedVisiblePerScreen": 8,
      "MatchRatio": 0.8,
      "LowConfidenceRetirementAfter": 5,
      "SkillId": "learned",
      "ProcessNameGlob": "PioneerPharmacy*"
    },
    "AutoExecution": {
      "Enabled": false,
      "RequireConfirmation": true,
      "WritebackEnabled": false
    },
    "Vision": {
      "Enabled": false
    },
    "FleetFeatures": {
      "SchemaAdaptation": false
    }
  },
  "MissionLoop": {
    "Phase1": {
      "Enabled": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
