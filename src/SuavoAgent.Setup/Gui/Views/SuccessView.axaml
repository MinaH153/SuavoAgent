<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SuavoAgent.Setup.Gui.ViewModels"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="540"
             x:Class="SuavoAgent.Setup.Gui.Views.SuccessView"
             x:DataType="vm:SuccessViewModel">

    <Grid RowDefinitions="*,Auto,Auto,Auto,*" Margin="80,32">

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Spacing="16">
            <Border Width="72" Height="72"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource SuavoSuccessBrush}"
                    CornerRadius="36">
                <TextBlock Text="✓"
                           Foreground="#101010"
                           FontSize="40" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="SuavoAgent is installed"
                       Foreground="{DynamicResource SuavoTextBrush}"
                       FontSize="34" FontWeight="Light"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="The agent will query for delivery-ready prescriptions every 5 minutes."
                       Foreground="{DynamicResource SuavoTextMutedBrush}"
                       FontSize="14"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="2" Margin="0,28,0,0"
                HorizontalAlignment="Center"
                MinWidth="440"
                Background="{DynamicResource SuavoCardBrush}"
                BorderBrush="{DynamicResource SuavoBorderBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource SuavoRadiusLarge}"
                Padding="22,16">
            <StackPanel Spacing="6">
                <Grid ColumnDefinitions="110,*">
                    <TextBlock Grid.Column="0" Text="Agent ID" Foreground="{DynamicResource SuavoTextSubtleBrush}" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding AgentId}" Foreground="{DynamicResource SuavoTextBrush}" FontSize="12" FontFamily="Consolas,Menlo,monospace"/>
                </Grid>
                <Grid ColumnDefinitions="110,*">
                    <TextBlock Grid.Column="0" Text="Install path" Foreground="{DynamicResource SuavoTextSubtleBrush}" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding InstallPath}" Foreground="{DynamicResource SuavoTextBrush}" FontSize="12" FontFamily="Consolas,Menlo,monospace"/>
                </Grid>
                <Grid ColumnDefinitions="110,*">
                    <TextBlock Grid.Column="0" Text="Data path" Foreground="{DynamicResource SuavoTextSubtleBrush}" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding DataPath}" Foreground="{DynamicResource SuavoTextBrush}" FontSize="12" FontFamily="Consolas,Menlo,monospace"/>
                </Grid>
                <Grid ColumnDefinitions="110,*">
                    <TextBlock Grid.Column="0" Text="SQL" Foreground="{DynamicResource SuavoTextSubtleBrush}" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding SqlSummary}" Foreground="{DynamicResource SuavoTextBrush}" FontSize="12" FontFamily="Consolas,Menlo,monospace" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,28,0,0">
            <Button Content="Open Suavo Cockpit"
                    Command="{Binding OpenDashboardCommand}"
                    Padding="24,12"
                    Background="{DynamicResource SuavoAccentBrush}"
                    Foreground="#101010"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    CornerRadius="10"/>
            <Button Content="Finish"
                    Command="{Binding FinishCommand}"
                    Padding="20,12"
                    Background="Transparent"
                    Foreground="{DynamicResource SuavoTextMutedBrush}"
                    BorderBrush="{DynamicResource SuavoBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"/>
        </StackPanel>

    </Grid>
</UserControl>
